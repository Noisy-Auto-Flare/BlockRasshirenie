{
  "manifest_version": 3,
  "name": "Hardcore YouTube Limiter",
  "version": "4.0.0",
  "description": "Жёсткий ограничитель времени просмотра YouTube с настраиваемыми параметрами и защитой от изменения настроек.",
  
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "action",
    "alarms",
    "tabs"
  ],
  
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "options_page": "options.html",
  
  "action": {
    "default_title": "YouTube Limiter - Вкладки",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html"
  },
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}